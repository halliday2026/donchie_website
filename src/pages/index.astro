---
import Layout from '../layouts/Layout.astro';

const phoneDisplay = '626-771-7471';
const phoneHref = 'tel:6267717471';
const emailAddress = 'archibon.lamaria1967@gmail.com';
const emailHref = `mailto:${emailAddress}`;

const testimonials = [
  {
    quote: 'Placeholder testimonial — share what made this client and their family feel cared for.',
    name: 'Client Name',
    relation: 'Family Member',
  },
  {
    quote: 'Placeholder testimonial — share what made this client and their family feel cared for.',
    name: 'Client Name',
    relation: 'Family Member',
  },
  {
    quote: 'Placeholder testimonial — share what made this client and their family feel cared for.',
    name: 'Client Name',
    relation: 'Family Member',
  },
];

const currentYear = new Date().getFullYear();

const services = [
  {
    icon: '🛁',
    title: 'Bathing Assistance',
    desc: 'Gentle, respectful help with bathing and hygiene that preserves dignity and comfort.',
  },
  {
    icon: '🛏️',
    title: 'Bedbound Bathing Assistance',
    desc: 'Specialized in-bed bathing care for clients with limited mobility, delivered with patience and skill.',
  },
  {
    icon: '🤝',
    title: 'Personal Care Services',
    desc: 'Day-to-day support with grooming, dressing, and personal needs so clients can stay comfortable at home.',
  },
];
---

<Layout title="Donchie | Licensed Home Health Aide in Upland, CA">
  <!-- Hero -->
  <section class="hero">
    <div class="hero__content">
      <h1 class="hero__title">Compassionate Care, In the Comfort of Home</h1>
      <p class="hero__subtitle">Licensed Home Health Aide serving the Inland Empire &amp; surrounding areas</p>
      <div class="hero__actions">
        <a class="btn-call" href={phoneHref}>Call or Text: {phoneDisplay}</a>
        <a class="btn-email" href={emailHref}>Email Us</a>
      </div>
    </div>
  </section>

  <!-- About -->
  <section class="about" id="about">
    <div class="container">
      <h2 class="section-title">About Donchie</h2>
      <p>
        Dona and Archie are licensed Home Health Aides dedicated to providing compassionate, dignified
        personal care for seniors in the comfort of their own home. With a personal commitment to
        every client's wellbeing, Donchie brings professional care with a family-like touch.
      </p>

      <div class="credential-badge">
        <svg class="credential-badge__seal" viewBox="0 0 64 64" aria-hidden="true">
          <circle cx="32" cy="32" r="29" fill="none" stroke="var(--color-silver)" stroke-width="2" />
          <circle cx="32" cy="32" r="22" fill="none" stroke="var(--color-white)" stroke-width="1.5" opacity="0.6" />
          <path
            d="M32 18 L35.5 27 L45 27.5 L37.5 33.5 L40 43 L32 37.5 L24 43 L26.5 33.5 L19 27.5 L28.5 27 Z"
            fill="var(--color-white)"
            opacity="0.9"
          />
        </svg>
        <div class="credential-badge__text">
          <p class="credential-badge__org">California Department of Public Health</p>
          <p class="credential-badge__title">Certified Home Health Aide</p>
          <p class="credential-badge__meta">Certificate #00266808 · Active through October 2026</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="services" id="services">
    <div class="container">
      <h2 class="section-title">Services</h2>
      <div class="services-grid">
        {services.map((service) => (
          <div class="service-card">
            <div class="service-card__icon" aria-hidden="true">{service.icon}</div>
            <h3 class="service-card__title">{service.title}</h3>
            <p class="service-card__desc">{service.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="testimonials" id="testimonials">
    <div class="container">
      <h2 class="section-title">What Families Are Saying</h2>
      <div class="testimonials-grid">
        {testimonials.map((t) => (
          <div class="testimonial-card">
            <p class="testimonial-card__quote">&ldquo;{t.quote}&rdquo;</p>
            <p class="testimonial-card__name">{t.name}</p>
            <p class="testimonial-card__relation">{t.relation}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Service Area Map -->
  <section class="map-section" id="service-area">
    <div class="container">
      <h2 class="section-title">Areas We Serve</h2>
      <img
        id="map"
        src={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/service_area_map.jpg`}
        alt="Map of the service area surrounding Upland, CA, including San Bernardino, Rialto, Riverside, Corona, Chino, and Covina"
        loading="lazy"
      />
    </div>
  </section>

  <!-- Contact / CTA -->
  <section class="contact" id="contact">
    <div class="container">
      <h2 class="section-title">Ready to Get Started?</h2>
      <p>Call or text anytime.</p>
      <div class="contact__actions">
        <a class="contact__phone" href={phoneHref}>{phoneDisplay}</a>
        <a class="btn-email" href={emailHref}>Email Us</a>
      </div>
    </div>
  </section>

  <footer>
    <p>&copy; {currentYear} Donchie · Licensed Home Health Aide · Upland, CA</p>
  </footer>
</Layout>
